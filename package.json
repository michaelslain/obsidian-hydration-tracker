{
	"name": "hydration-tracker",
	"version": "1.0.0",
	"description": "Track daily hydration with drink database, caffeine, sugar, and goals.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "bun esbuild.config.mjs",
		"build": "bun esbuild.config.mjs production",
		"version": "bun version-bump.mjs && git add manifest.json versions.json",
		"obsidian": "open -a Obsidian",
		"obsidian:debug": "/Applications/Obsidian.app/Contents/MacOS/Obsidian --remote-debugging-port=9222",
		"start": "concurrently \"bun esbuild.config.mjs\" \"/Applications/Obsidian.app/Contents/MacOS/Obsidian --remote-debugging-port=9222\"",
		"playwright": "npx @playwright/mcp --cdp-endpoint http://localhost:9222"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@preact/signals": "^2.8.1",
		"@types/node": "^16.11.6",
		"builtin-modules": "^5.0.0",
		"concurrently": "^9.2.1",
		"esbuild": "0.25.5",
		"tslib": "2.4.0",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"obsidian": "latest",
		"preact": "^10.28.4"
	}
}
