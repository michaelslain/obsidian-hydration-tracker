{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowImportingTsExtensions": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"lib": ["DOM", "ES5", "ES6", "ES7"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
